# ── Claude CLI ───────────────────────────────────────────────────────────
# Claude Code CLI 可执行文件路径（或 PATH 中的命令名）
CLAUDE_EXE=claude
# Claude 运行的工作目录（项目根目录）
CLAUDE_CWD=/path/to/your/project

# ── 身份（提示词自动引用，无需改代码）──────────────────────────────────────
ASSISTANT_NAME=Claude
USER_NICKNAME=User

# ── 服务 ─────────────────────────────────────────────────────────────────
# 监听端口
BRIDGE_PORT=8765
# (optional) 数据目录名，默认 data；测试可设 data_test 隔离
# BRIDGE_DATA=data

# (optional) TLS：两者都配置时 python server.py 直接以 HTTPS 启动（前端自动用 wss://）。
# 留空 = 明文 HTTP（仅本机，或已由反代/隧道处理 TLS）。
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# ── 记忆服务（optional，可插拔）─────────────────────────────────────────────
# 留空 = 无记忆，bridge 作为纯 Claude Code 终端。
# 配置后 bridge 通过 HTTP 把记忆方法转发给该服务（契约见 README）。
# MEMORY_SERVICE_URL=http://127.0.0.1:8780
# (optional) HTTP 记忆调用超时（秒），默认 10
# MEMORY_SERVICE_TIMEOUT=10
