# 配置项清单。核心经 create_app(config) 的参数接收配置（见 README 的 run.py 示例）；
# README 示例只从环境变量读 BRIDGE_PORT，其余项由你的 run.py 自行读入（os.environ /
# python-dotenv 均可）后传给 create_app。

# ── Claude CLI ───────────────────────────────────────────────────────────
# Claude Code CLI 可执行文件路径（或 PATH 中的命令名）
CLAUDE_EXE=claude
# Claude 运行的工作目录（项目根目录）
CLAUDE_CWD=/path/to/your/project

# ── 身份（demo 前端启动时 GET /config 读取；核心不带该路由，由插件/调用方经
#    register_routes 提供，未提供时前端回退默认值 Claude / User）──────────
ASSISTANT_NAME=Claude
USER_NICKNAME=User

# ── 服务 ─────────────────────────────────────────────────────────────────
# 监听端口（README 的 run.py 示例从环境读取，默认 8765）
BRIDGE_PORT=8765
# 数据目录（chat.db 所在处）经 create_app 的 DATA_DIR 配置项指定，见 run.py 示例

# TLS：核心只跑明文 HTTP，不做 TLS 终结。需要 HTTPS（PWA 安装等安全上下文能力）时
# 由反代/隧道在外层终结 TLS——推荐 Tailscale serve，见 README「Reach it from your phone」。

# ── 记忆服务（optional，可插拔）─────────────────────────────────────────────
# 留空 = 无记忆，bridge 作为纯 Claude Code 终端。
# 配置后 bridge 通过 HTTP 把记忆方法转发给该服务（契约见 README）。
# MEMORY_SERVICE_URL=http://127.0.0.1:8780
# (optional) HTTP 记忆调用超时（秒），默认 10
# MEMORY_SERVICE_TIMEOUT=10
